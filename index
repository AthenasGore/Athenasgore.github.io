    <title>Tu Blog</title>
    <link rel="stylesheet" href="estilos.css"> <!-- Enlaza tu archivo de estilos CSS -->
    <style>
        body {
            text-align: center; /* Centra el contenido */
            background-color: #f0f0f0; /* Color de fondo */
        }
        header {
            background-color: #333; /* Color de fondo del encabezado */
            color: white; /* Color del texto del encabezado */
            padding: 20px;
        }
        nav ul {
            list-style: none;
            padding: 0;
        }
        nav li {
            display: inline;
            margin-right: 20px;
        }
        main {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
        }
        article {
            width: 30%;
            margin: 10px;
            padding: 20px;
            background-color: white; /* Color de fondo del artículo */
            border: 1px solid #ccc; /* Borde del artículo */
            text-align: left;
        }
        aside {
            width: 30%;
            padding: 20px;
            background-color: white; /* Color de fondo de la barra lateral */
            border: 1px solid #ccc; /* Borde de la barra lateral */
            text-align: left;
        }
        footer {
            background-color: #333; /* Color de fondo del pie de página */
            color: white; /* Color del texto del pie de página */
            padding: 10px;
        }
    </style>
</head>
